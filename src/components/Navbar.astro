---
import { Sheet, SheetContent, SheetTrigger } from '@/components/ui/sheet';
import { Button } from '@/components/ui/button';
import { cn } from '@/lib/utils'; // утилита из shadcn (если нет — создай src/lib/utils.ts)

const { currentPath = Astro.url.pathname } = Astro.props;

const links = [
  { href: '/', label: 'Etusivu' },
  { href: '/lappeenranta', label: 'Lappeenranta' },
  { href: '/blog', label: 'Artikkelit' },
  { href: '/yhteystiedot', label: 'Yhteystiedot' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-white/70 dark:bg-slate-900/70 border-b border-slate-200/50 dark:border-slate-800/50 transition-all duration-300">
  <div class="container mx-auto px-6 h-16 md:h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-[#30D5C8] to-[#2A9D8F] bg-clip-text text-transparent tracking-tight">
      Saimaa Kesä
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class={cn(
            "font-medium text-sm transition-colors hover:text-[#30D5C8] relative py-2",
            currentPath === link.href && "text-[#30D5C8] after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-[#30D5C8]"
          )}
        >
          {link.label}
        </a>
      ))}
      <Button asChild variant="default" size="sm" class="ml-4 rounded-full shadow-md hover:shadow-lg">
        <a href="https://avia.saimaanliikenne.fi" target="_blank" rel="noopener noreferrer">
          Etsi lennot ✈️
        </a>
      </Button>
    </nav>

    <!-- Mobile Menu Trigger -->
    <Sheet>
      <SheetTrigger asChild class="md:hidden">
        <Button variant="ghost" size="icon" class="rounded-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
          <span class="sr-only">Avaa valikko</span>
        </Button>
      </SheetTrigger>

      <SheetContent side="right" class="w-full sm:w-[400px] bg-gradient-to-b from-white to-slate-50 dark:from-slate-950 dark:to-slate-900 border-l border-slate-200 dark:border-slate-800">
        <div class="flex flex-col h-full">
          <div class="flex items-center justify-between mb-8">
            <a href="/" class="text-2xl font-bold bg-gradient-to-r from-[#30D5C8] to-[#2A9D8F] bg-clip-text text-transparent">
              Saimaa Kesä
            </a>
            <SheetTrigger asChild>
              <Button variant="ghost" size="icon" class="rounded-full">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
              </Button>
            </SheetTrigger>
          </div>

          <nav class="flex flex-col gap-6 text-lg font-medium">
            {links.map(link => (
              <a
                href={link.href}
                class={cn(
                  "transition-colors hover:text-[#30D5C8] py-2 border-b border-slate-200 dark:border-slate-800",
                  currentPath === link.href && "text-[#30D5C8] font-semibold"
                )}
              >
                {link.label}
              </a>
            ))}
          </nav>

          <div class="mt-auto pb-8">
            <Button asChild class="w-full rounded-full py-6 text-lg shadow-lg hover:shadow-xl bg-gradient-to-r from-[#30D5C8] to-[#2A9D8F] hover:from-[#26b8ac] hover:to-[#1f8a7a]">
              <a href="https://avia.saimaanliikenne.fi" target="_blank" rel="noopener noreferrer">
                Etsi lennot Saimaalle ✈️
              </a>
            </Button>
          </div>
        </div>
      </SheetContent>
    </Sheet>
  </div>
</header>

<!-- Spacer чтобы контент не залезал под фиксированный header -->
<div class="h-16 md:h-20"></div>
