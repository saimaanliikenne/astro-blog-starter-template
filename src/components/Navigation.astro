---
// src/components/Navigation.astro
const { currentPage = 'home' } = Astro.props;
---

<nav class="main-nav">
  <div class="nav-container">
    <!-- Логотип -->
    <a href="/" class="logo">
      Matkatoimisto Saimaan Liikenne OY
    </a>

    <!-- Десктопное меню -->
    <div class="nav-links">
      <a href="/" class={currentPage === 'home' ? 'active' : ''}>Etusivu</a>
      <a href="/lappeenranta" class={currentPage === 'lappeenranta' ? 'active' : ''}>Lappeenranta</a>
      <a href="/imatra" class={currentPage === 'imatra' ? 'active' : ''}>Imatra</a>
      <a href="/puistot" class={currentPage === 'retkeily' ? 'active' : ''}>Kansallispuistot & Retkeily</a>
      <a href="/contact" class={currentPage === 'contact' ? 'active' : ''}>Contact</a>
    </div>

    <!-- Мобильное меню (гамбургер) -->
    <button class="mobile-menu-btn" aria-label="Avaa valikko">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

<style>
  .main-nav {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #e0f0f0;
  }

  .nav-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    color: #006666;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 2.2rem;
  }

  .nav-links a {
    color: #333;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: #00b7b7;
    position: relative;
  }

  .nav-links a.active::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 100%;
    height: 2px;
    background: #00b7b7;
  }

  /* Мобильная кнопка */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .mobile-menu-btn span {
    width: 28px;
    height: 3px;
    background: #006666;
    transition: all 0.3s;
  }

  /* Мобильное меню */
  .mobile-menu {
    display: none;
    flex-direction: column;
    background: white;
    padding: 1.5rem 2rem;
    border-top: 1px solid #eee;
  }

  .mobile-menu a {
    padding: 1rem 0;
    color: #333;
    text-decoration: none;
    font-size: 1.1rem;
    border-bottom: 1px solid #f0f0f0;
  }

  /* Адаптивность */
  @media (max-width: 868px) {
    .nav-links {
      display: none;
    }
    
    .mobile-menu-btn {
      display: flex;
    }

    .mobile-menu {
      display: flex;
    }
  }
</style>

<script>
  // Простая логика открытия/закрытия мобильного меню
  const menuBtn = document.querySelector('.mobile-menu-btn');
  const mobileMenu = document.querySelector('.mobile-menu');

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('active');
      
      // Анимация гамбургера
      const spans = menuBtn.querySelectorAll('span');
      if (mobileMenu.classList.contains('active')) {
        spans[0].style.transform = 'rotate(45deg) translate(6px, 6px)';
        spans[1].style.opacity = '0';
        spans[2].style.transform = 'rotate(-45deg) translate(5px, -5px)';
      } else {
        spans[0].style.transform = 'none';
        spans[1].style.opacity = '1';
        spans[2].style.transform = 'none';
      }
    });
  }
</script>
