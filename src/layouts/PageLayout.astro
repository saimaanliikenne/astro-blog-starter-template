---
/**
 * PageLayout.astro — Главный layout с меню
 */
import Navigation from '../components/Navigation.astro';
import { ViewTransitions } from 'astro:transitions';

const { title = 'Matkatoimisto Saimaan Liikenne OY', description = 'Unohtumattomat kesälomat Saimaalla' } = Astro.props;
---

<!doctype html>
<html lang="fi" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet" />

    <ViewTransitions fallback="animate" />
  </head>

  <body>
    <!-- Навигация -->
    <Navigation currentPath={Astro.url.pathname} />

    <!-- Основной контент -->
    <main class="pt-20 md:pt-24 pb-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-container">
        <div class="footer-brand">
          <h3 class="footer-logo">Matkatoimisto Saimaan Liikenne OY</h3>
          <p>Unohtumattomat hetket Suomen suurimmalla järvellä</p>
        </div>
        <div class="footer-contacts">
          <h4>Yhteystiedot</h4>
          <ul>
            <li>📧 <a href="mailto:info@saimaanliikenne.fi">info@saimaanliikenne.fi</a></li>
            <li>📞 +358 50 556 8889</li>
            <li>📍 Kauppakatu 40 B 27, 53100 Lappeenranta</li>
          </ul>
        </div>
        <div class="footer-social">
          <h4>Seuraa meitä</h4>
          <div class="social-icons">
            <a href="#" target="_blank">Instagram</a>
            <a href="#" target="_blank">Facebook</a>
            <a href="#" target="_blank">Pinterest</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Matkatoimisto Saimaan Liikenne OY. Kaikki oikeudet pidätetään.</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --primary: #2a6b5f;
        --accent: #30d5c8;
        --bg: #f8f9f7;
        --text: #1a2a2a;
      }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        background: hsl(var(--bg));
        color: hsl(var(--text));
        margin: 0;
        line-height: 1.6;
      }

      h1, h2, h3 {
        font-family: 'Playfair Display', serif;
      }

      .pt-20 { padding-top: 5rem; }
      .md\:pt-24 { padding-top: 6rem; }

      /* Footer */
      .footer {
        background: linear-gradient(135deg, #1e3a5f 0%, #2a6b5f 100%);
        color: #e0f7fa;
        padding: 4rem 1.5rem 2rem;
        margin-top: 5rem;
      }
      .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 3rem;
      }
      .footer-logo {
        font-size: 2.1rem;
        color: #30d5c8;
        margin-bottom: 0.8rem;
      }
      .footer-contacts h4,
      .footer-social h4 {
        color: white;
        margin-bottom: 1.2rem;
      }
      .social-icons a {
        color: #b2f2ea;
        margin-right: 1.5rem;
      }
      .footer-bottom {
        text-align: center;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255,255,255,0.2);
        opacity: 0.85;
      }
    </style>
  </body>
</html>
