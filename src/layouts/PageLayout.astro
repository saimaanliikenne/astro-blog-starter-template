---
/**
 * PageLayout.astro
 * Современный базовый layout для astro-blog-starter-template
 * 2026 стиль: Tailwind v4 + dark mode + smooth transitions
 */

import { ViewTransitions } from 'astro:transitions'; // плавные переходы между страницами (Astro 4+)

const { title = 'Matkatoimisto Saimaan Liikenne OY', description = 'Unohtumattomat kesälomat Saimaalla' } = Astro.props;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="fi" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Matkatoimisto Saimaan Liikenne" />

    <!-- Open Graph / Social sharing -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="/og-image.jpg" /> <!-- добавь своё og-изображение в public/ -->

    <!-- Favicon и PWA basics -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Google Fonts: современная комбинация -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <!-- View Transitions для плавной навигации -->
    <ViewTransitions fallback="animate" />

    <!-- Tailwind + custom styles -->
    <style is:global>
      :root {
        --color-primary: 42 107 95;     /* глубокий бирюзово-зелёный для Саймаа */
        --color-accent: 48 213 200;     /* яркий бирюзовый #30D5C8 */
        --color-bg: 248 249 247;        /* светлый фон #f8f9f7 */
        --color-text: 26 42 42;         /* тёмный текст */
      }

      [data-theme="dark"] {
        --color-bg: 15 23 42;           /* slate-900 */
        --color-text: 226 232 240;      /* slate-200 */
      }

      html {
        @apply bg-[hsl(var(--color-bg))] text-[hsl(var(--color-text))];
      }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        @apply min-h-screen antialiased;
      }

      h1, h2, h3 {
        font-family: 'Playfair Display', serif;
        @apply font-semibold tracking-tight;
      }

      /* Плавные hover и focus */
      a, button {
        @apply transition-all duration-300 ease-out;
      }

      a:hover, button:hover {
        @apply scale-[1.02];
      }

      /* Кастомные утилиты */
      .btn-primary {
        @apply px-6 py-3 rounded-full font-medium text-white bg-[hsl(var(--color-accent))] hover:bg-[hsl(calc(var(--color-accent)-30))] shadow-lg hover:shadow-xl;
      }

      .container {
        @apply max-w-7xl mx-auto px-6 lg:px-8;
      }
    </style>
  </head>

  <body class="bg-[hsl(var(--color-bg))] text-[hsl(var(--color-text))] transition-colors duration-500">
    <!-- Skip link для доступности -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded focus:shadow-lg">
      Siirry pääsisältöön
    </a>

    <!-- Header / Navigation -->
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-lg bg-white/70 dark:bg-slate-900/70 border-b border-slate-200/50 dark:border-slate-800/50 transition-colors">
      <div class="container flex items-center justify-between h-16 md:h-20">
        <!-- Logo -->
        <a href="/" class="text-2xl md:text-3xl font-bold text-[hsl(var(--color-accent))] tracking-tight">
          Saimaa Kesä
        </a>

        <!-- Navigation -->
        <nav class="hidden md:flex items-center gap-8">
          <a href="/" class="hover:text-[hsl(var(--color-accent))] font-medium">Etusivu</a>
          <a href="/blog" class="hover:text-[hsl(var(--color-accent))] font-medium">Artikkelit</a>
          <a href="/lappeenranta" class="hover:text-[hsl(var(--color-accent))] font-medium">Lappeenranta</a>
          <a href="/yhteystiedot" class="hover:text-[hsl(var(--color-accent))] font-medium">Yhteystiedot</a>
        </nav>

        <!-- Dark mode toggle + mobile menu button -->
        <div class="flex items-center gap-4">
          <!-- Dark mode (можно сделать через JS или astro-integration) -->
          <button id="theme-toggle" aria-label="Vaihda teema" class="p-2 rounded-full hover:bg-slate-200 dark:hover:bg-slate-800">
            <span class="sr-only">Teema</span>
            <!-- Иконки можно заменить на lucide-react или heroicons -->
            🌙 / ☀️
          </button>

          <!-- Mobile menu button -->
          <button class="md:hidden p-2 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-800" aria-label="Avaa valikko">
            ☰
          </button>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main id="main-content" class="pt-20 md:pt-24 pb-16">
      <slot />  <!-- Здесь будет контент страниц -->
    </main>

    <!-- Footer -->
    <footer class="bg-gradient-to-t from-[hsl(var(--color-primary))] to-[hsl(calc(var(--color-primary)+20))] text-white py-12">
      <div class="container text-center">
        <p class="text-lg mb-4">
          Unohtumattomat hetket Suomen suurimmalla järvellä
        </p>

        <div class="flex justify-center gap-6 mb-6">
          <a href="https://instagram.com" target="_blank" rel="noopener" class="hover:text-[hsl(var(--color-accent))] transition-colors">Instagram</a>
          <a href="https://facebook.com" target="_blank" rel="noopener" class="hover:text-[hsl(var(--color-accent))] transition-colors">Facebook</a>
        </div>

        <p class="text-sm opacity-80">
          © {currentYear} Matkatoimisto Saimaan Liikenne OY. Kaikki oikeudet pidätetään.
        </p>
      </div>
    </footer>

    <!-- Простой JS для dark mode toggle (можно вынести в отдельный .js) -->
    <script>
      const toggle = document.getElementById('theme-toggle');
      if (toggle) {
        toggle.addEventListener('click', () => {
          document.documentElement.dataset.theme = 
            document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          localStorage.setItem('theme', document.documentElement.dataset.theme);
        });

        // Загрузка сохранённой темы
        const saved = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = saved;
      }
    </script>
  </body>
</html>
