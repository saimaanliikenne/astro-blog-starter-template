---
/**
 * PageLayout.astro — Основной layout
 */
import Navigation from '../components/Navigation.astro';
import { ViewTransitions } from 'astro:transitions';

const { title = 'Matkatoimisto Saimaan Liikenne OY', description = 'Unohtumattomat kesälomat Saimaalla' } = Astro.props;
---

<!doctype html>
<html lang="fi" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="/og-image.jpg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap" rel="stylesheet" />

    <ViewTransitions fallback="animate" />
  </head>

  <body class="bg-[hsl(var(--color-bg))] text-[hsl(var(--color-text))] transition-colors duration-500">
    
    <!-- Навигация -->
    <Navigation currentPath={Astro.url.pathname} />

    <!-- Основной контент -->
    <main class="pt-20 md:pt-24 pb-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-container">
        <div class="footer-brand">
          <h3 class="footer-logo">Matkatoimisto Saimaan Liikenne OY</h3>
          <p>Unohtumattomat hetket Suomen suurimmalla järvellä</p>
        </div>
        <div class="footer-contacts">
          <h4>Yhteystiedot</h4>
          <ul>
            <li>📧 <a href="mailto:info@saimaanliikenne.fi">info@saimaanliikenne.fi</a></li>
            <li>📞 +358 50 556 8889</li>
            <li>📍 Kauppakatu 40 B 27, 53100 Lappeenranta</li>
          </ul>
        </div>
        <div class="footer-social">
          <h4>Seuraa meitä</h4>
          <div class="social-icons">
            <a href="#" target="_blank">Instagram</a>
            <a href="#" target="_blank">Facebook</a>
            <a href="#" target="_blank">Pinterest</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© {new Date().getFullYear()} Matkatoimisto Saimaan Liikenne OY. Kaikki oikeudet pidätetään.</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --color-primary: 42 107 95;
        --color-accent: 48 213 200;
        --color-bg: 248 249 247;
        --color-text: 26 42 42;
      }

      body {
        font-family: 'Inter', system-ui, sans-serif;
      }
      h1, h2, h3 {
        font-family: 'Playfair Display', serif;
      }

      .main-nav { /* стили уже в компоненте */ }

      .footer {
        background: linear-gradient(135deg, #1e3a5f 0%, #2a6b5f 100%);
        color: #e0f7fa;
        padding: 4rem 2rem 2rem;
        margin-top: 6rem;
        border-top: 4px solid #30D5C8;
      }
      .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 3rem;
      }
      .footer-logo {
        font-size: 2.2rem;
        color: #30D5C8;
        margin-bottom: 0.8rem;
      }
      .footer-contacts h4,
      .footer-social h4 {
        font-size: 1.4rem;
        margin-bottom: 1.2rem;
        color: white;
      }
      .social-icons {
        display: flex;
        gap: 1.8rem;
      }
      .social-icons a:hover {
        color: #30D5C8;
      }
      .footer-bottom {
        text-align: center;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255,255,255,0.15);
        opacity: 0.85;
      }
    </style>
  </body>
</html>
