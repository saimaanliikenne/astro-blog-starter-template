---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Lappeenranta – Saimaan kesäkaupunki">
  <!-- весь контент страницы здесь -->
<section class="photo-text-block py-16 bg-white dark:bg-slate-900">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <!-- Фото слева -->
      <div class="overflow-hidden rounded-2xl shadow-2xl order-2 md:order-1">
        <img 
          src="https://images.unsplash.com/photo-1580130718646-9f694209b207?auto=format&fit=crop&q=85&w=1200" 
          alt="Lappeenrannan satama kesällä"
          class="w-full h-auto object-cover transition-transform duration-700 hover:scale-105"
          loading="lazy"
        />
      </div>
      
      <!-- Текст справа -->
      <div class="order-1 md:order-2">
        <h2 class="text-3xl md:text-4xl font-serif mb-6 text-[#30D5C8]">
          Lappeenrannan satama
        </h2>
        <p class="text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6">
          Kesäinen satama on vilkas keskus, josta lähtevät risteilyt Saimaalle. 
          Voit vuokrata polkupyörän tai veneen ja tutkia järveä omassa tahdissa.
        </p>
        <a 
          href="https://avia.saimaanliikenne.fi" 
          target="_blank" 
          class="inline-block px-8 py-4 bg-[#30D5C8] text-white font-medium rounded-full shadow-lg hover:bg-[#26b8ac] transition-all"
        >
          Etsi lennot tänne ✈️
        </a>
      </div>
    </div>
  </div>
</section>
<section class="photo-block py-12 md:py-16 bg-gradient-to-b from-slate-50 to-white dark:from-slate-950 dark:to-slate-900">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-serif text-center mb-8 text-[#30D5C8]">
      Kauniit Saimaan maisemat
    </h2>
    
    <div class="overflow-hidden rounded-2xl shadow-2xl">
      <img 
        src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&q=85&w=1600" 
        alt="Kesäinen Saimaa järvi maisema Suomessa"
        class="w-full h-auto object-cover transition-transform duration-700 hover:scale-105"
        loading="lazy"
      />
    </div>
    
    <p class="text-center mt-6 text-lg text-slate-600 dark:text-slate-300 max-w-3xl mx-auto">
      Kirkas vesi, vihreät saaret ja aurinkoinen kesä – Saimaa kutsuu rentoutumaan.
    </p>
  </div>
</section>
<section class="photo-gallery py-12 md:py-20">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-serif text-center mb-10 text-[#2a6b5f]">
      Tutustu Saimaan tunnelmaan
    </h2>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      <!-- Фото 1: озеро -->
      <div class="group overflow-hidden rounded-xl shadow-lg hover:shadow-2xl transition-all duration-500">
        <img 
          src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&q=85&w=800" 
          alt="Saimaa järvi kesäpäivänä"
          class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-700"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
          <p class="text-white text-lg font-medium">Järvimaisemat</p>
        </div>
      </div>

      <!-- Фото 2: коттедж у озера -->
      <div class="group overflow-hidden rounded-xl shadow-lg hover:shadow-2xl transition-all duration-500">
        <img 
          src="https://images.unsplash.com/photo-1620121681033-8b68cfbdcded?auto=format&fit=crop&q=85&w=800" 
          alt="Perinteinen mökki Saimaan rannalla"
          class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-700"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
          <p class="text-white text-lg font-medium">Mökkielämää</p>
        </div>
      </div>

      <!-- Фото 3: закат над озером -->
      <div class="group overflow-hidden rounded-xl shadow-lg hover:shadow-2xl transition-all duration-500">
        <img 
          src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&q=85&w=800" 
          alt="Auringonlasku Saimaalla"
          class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-700"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
          <p class="text-white text-lg font-medium">Auringonlaskut</p>
        </div>
      </div>
    </div>
  </div>
</section>
</PageLayout>
