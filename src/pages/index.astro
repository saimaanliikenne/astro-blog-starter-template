---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout 
  title="Matkatoimisto Saimaan Liikenne OY" 
  description="Unohtumattomat kesälomat Saimaalla – lennot, hotellit ja retkeily Etelä-Karjalassa">
  
  <!-- Hero Section -->
  <div class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Avaa Saimaa<br> kanssamme</h1>
      <p class="lead">Unohtumattomat matkat, upeat luontokohteet ja aidot elämykset Etelä-Karjalassa</p>
      
      <!-- Travelpayouts Widget -->
      <div class="tp-widget-wrapper">
        <script async src="https://tpwgt.com/content?currency=eur&trs=279173&shmarker=498238&show_hotels=true&powered_by=true&locale=fi&searchUrl=search.jetradar.com&primary_override=%2332a8dd&color_button=%2332a8dd&color_icons=%2332a8dd&dark=%23262626&light=%23FFFFFF&secondary=%23FFFFFF&special=%23C4C4C4&color_focused=%2332a8dd&border_radius=0&plain=false&origin=HEL&promo_id=7879&campaign_id=100" charset="utf-8"></script>
      </div>

      <div class="popular-destinations">
        <span>Suositut kohteet:</span>
        <div class="tags">
          <a href="/imatra">Imatra</a>
          <a href="/lappeenranta">Lappeenranta</a>
          <a href="/retkeily">Kansallispuistot</a>
          <a href="#">Saimaa</a>
          <a href="#">Ruunaa</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Info Cards -->
  <section class="section quick-info">
    <div class="container">
      <div class="cards">
        <div class="card">
          <div class="card-icon">🌲</div>
          <h3>Retkeily & Luonto</h3>
          <p>Imatrankoski, Petkeljärvi ja Ruunaa – upeat kansallispuistot ja retkeilyreitit</p>
          <a href="/retkeily" class="card-link">Tutustu reitteihin →</a>
        </div>
        
        <div class="card">
          <div class="card-icon">🏨</div>
          <h3>Hotellit & Kylpylät</h3>
          <p>Laadukkaat majoitukset Saimaan rannalla ja Imatran kylpylässä</p>
          <a href="#" class="card-link">Etsi majoitusta →</a>
        </div>
        
        <div class="card">
          <div class="card-icon">✈️</div>
          <h3>Lomat & Aktiviteetit</h3>
          <p>Risteilyt, kalastus, SUP-lautailu ja monet muut kesän elämykset</p>
          <a href="#" class="card-link">Katso tarjoukset →</a>
        </div>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .hero {
    height: 92vh;
    min-height: 680px;
    background: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&q=80&w=2400') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
    position: relative;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 120, 130, 0.35), rgba(0, 60, 80, 0.75));
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 820px;
    padding: 0 20px;
  }

  .hero h1 {
    font-size: clamp(3.4rem, 8.5vw, 6.8rem);
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 1.2rem;
    text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  .lead {
    font-size: clamp(1.35rem, 3.5vw, 2.1rem);
    margin-bottom: 2.5rem;
    opacity: 0.95;
  }

  .tp-widget-wrapper {
    max-width: 720px;
    margin: 2rem auto 3rem;
    background: rgba(255,255,255,0.95);
    border-radius: 20px;
    padding: 1.8rem;
    box-shadow: 0 15px 50px rgba(0,0,0,0.2);
  }

  .popular-destinations {
    margin-top: 1rem;
  }

  .popular-destinations span {
    display: block;
    margin-bottom: 0.8rem;
    opacity: 0.9;
    font-size: 1.1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
  }

  .tags a {
    background: rgba(255,255,255,0.25);
    backdrop-filter: blur(8px);
    padding: 0.55rem 1.4rem;
    border-radius: 50px;
    color: white;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s;
  }

  .tags a:hover {
    background: rgba(255,255,255,0.45);
    transform: translateY(-3px);
  }

  /* Quick Info Section */
  .quick-info {
    padding: 6rem 0 7rem;
    background: linear-gradient(to bottom, #f8ffff, #e6f4f4);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .card {
    background: white;
    padding: 2.5rem 2rem;
    border-radius: 20px;
    box-shadow: 0 10px 35px rgba(0,0,0,0.08);
    text-align: center;
    transition: all 0.4s ease;
  }

  .card:hover {
    transform: translateY(-12px);
    box-shadow: 0 20px 45px rgba(0,0,0,0.12);
  }

  .card-icon {
    font-size: 3.5rem;
    margin-bottom: 1.2rem;
  }

  .card h3 {
    color: #006666;
    margin-bottom: 1rem;
    font-size: 1.45rem;
  }

  .card-link {
    color: #00b7b7;
    font-weight: 600;
    text-decoration: none;
    margin-top: 1.2rem;
    display: inline-block;
  }

  @media (max-width: 640px) {
    .tp-widget-wrapper {
      margin: 1.5rem 1rem;
      padding: 1.2rem;
    }
  }
</style>
