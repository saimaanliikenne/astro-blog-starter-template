---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Matkailu Suomessa – reitit, luonto ja rauha"
  description="Turistinen sivusto Suomesta: luontoreitit, kaupungit, blogi ja rauhallinen matkailu."
>

  <!-- HERO PREMIUM -->
  <section class="hero">
    <div class="hero-overlay">
      <div class="hero-content">
        <h1>Matkatoimisto Saimaan Liikenne</h1>
        <p>  Löydä Suomen kauneimmat luontokohteet,
      reitit ja rauhallinen matkailu.</p>
        <a href="/contact" class="btn-primary">Tutustu reitteihin</a>
      </div>
    </div>
  </section>

  <!-- SECTION 1 -->
  <section class="section fade-in">
    <div class="image">
      <img src="/images/routes/seasons.jpg" alt="Rauhallinen matkailu" />
    </div>
    <div class="text">
      <h2>Rauhallinen matkailu</h2>
      <p>
      Suomi tarjoaa ainutlaatuisen mahdollisuuden matkustaa ilman kiirettä. 
      Metsät, järvet ja pienet kaupungit luovat täydellisen ympäristön
      levolliseen lomaan.

      </p>
    </div>
  </section>

  <!-- SECTION 2 -->
  <section class="section reverse fade-in">
    <div class="image">
      <img src="/images/blog/winter-blog.jpg" alt="Finnish lake nature" />
    </div>
    <div class="text">
      <h2>Reitit ja kohteet</h2>
      <p>
        Tutustu vaellusreitteihin, pyöräilyyn, luontopolkuihin ja kaupunkikävelyihin.
  Jokainen reitti on valittu huolella matkailijoille, jotka arvostavat laatua ja rauhaa.

      </p>
    </div>
  </section>

  <!-- SECTION 3 -->
  <section class="section fade-in">
    <div class="image">
      <img src="/images/blog/forest-blog.jpg" alt="Sunset cruise" />
    </div>
    <div class="text">
      <h2><Matkablogi</h2>
      <p>
         Blogissamme jaamme kokemuksia, vinkkejä ja tarinoita matkailusta Suomessa.
      Löydät reittikuvauksia, valokuvia ja käytännön neuvoja..
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <h2>Ready for an unforgettable journey?</h2>
    <a href="/contact" class="btn-primary">Contact Us</a>
  </section>

</PageLayout>

<style>

/* ================= HERO ================= */

.hero {
  position: relative;
  height: 100vh;
  background-image: url('/images/hero/hero-premium.jpg');
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-overlay {
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,0.4),
    rgba(0,0,0,0.6)
  );
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-content {
  text-align: center;
  color: white;
  max-width: 800px;
  padding: 20px;
  animation: fadeHero 1.5s ease forwards;
  opacity: 0;
}

.hero-content h1 {
  font-size: 3.5rem;
  letter-spacing: 2px;
  margin-bottom: 20px;
  font-weight: 600;
}

.hero-content p {
  font-size: 1.4rem;
  margin-bottom: 40px;
}

.btn-primary {
  padding: 14px 40px;
  background: white;
  color: #0fa3b1;
  text-decoration: none;
  font-weight: 600;
  border-radius: 50px;
  transition: all 0.3s ease;
}

.btn-primary:hover {
  background: #0fa3b1;
  color: white;
  transform: translateY(-3px);
}

@keyframes fadeHero {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ================= SECTIONS ================= */
.section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  padding: 100px 10%;
}

.section.reverse {
  direction: rtl;
}

.section.reverse .text {
  direction: ltr;
}

.section img {
  width: 100%;
  height: 420px;
  object-fit: cover;
  border-radius: 20px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.15);
  transition: transform 0.4s ease;
}

.section img:hover {
  transform: scale(1.03);
}

.section h2 {
  font-size: 2rem;
  margin-bottom: 20px;
}

.section p {
  font-size: 1.1rem;
  line-height: 1.6;
}

/* ================= CTA ================= */

.cta {
  display: inline-block;
  background: #20c5c9;
  color: #ffffff;
  padding: 0.75rem 1.75rem;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 500;
}

.cta:hover {
  opacity: 0.9;
}

/* ================= ANIMATION ================= */

.fade-in {
  opacity: 0;
  transform: translateY(50px);
  transition: all 0.8s ease;
}

.fade-in.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ================= RESPONSIVE ================= */

@media (max-width: 900px) {

  .hero {
    background-attachment: scroll;
  }

  .hero-content h1 {
    font-size: 2.2rem;
  }

  .section {
    grid-template-columns: 1fr;
    padding: 60px 20px;
  }

  .section.reverse {
    direction: ltr;
  }

  .section img {
    height: 300px;
  }
}

</style>

<script>
  const elements = document.querySelectorAll('.fade-in');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.2 });

  elements.forEach(el => observer.observe(el));
</script>
