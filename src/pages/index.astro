---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout 
  title="Matkatoimisto Saimaan Liikenne OY" 
  description="Unohtumattomat lomat Saimaalla – Imatra, Lappeenranta ja Etelä-Karjala">
  
  <!-- Hero -->
  <div class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Tervetuloa<br>Saimaalle</h1>
      <p class="lead">Ainutlaatuisia elämyksiä, upeaa luontoa ja unohtumattomia lomia Etelä-Karjalassa</p>
      
      <div class="tp-widget-wrapper">
        <script async src="https://tpwgt.com/content?currency=eur&trs=279173&shmarker=498238&show_hotels=true&powered_by=true&locale=fi&searchUrl=search.jetradar.com&primary_override=%2332a8dd&color_button=%2332a8dd&color_icons=%2332a8dd&dark=%23262626&light=%23FFFFFF&secondary=%23FFFFFF&special=%23C4C4C4&color_focused=%2332a8dd&border_radius=0&plain=false&origin=HEL&promo_id=7879&campaign_id=100" charset="utf-8"></script>
      </div>
    </div>
  </div>

  <!-- Destinations -->
  <section class="section destinations">
    <div class="container">
      <h2 class="section-title">Suosituimmat kohteet</h2>
      <div class="destinations-grid">
        <a href="/lappeenranta" class="destination-card">
          <img src="/images/blog/lappeenranta.jpg" alt="Lappeenranta">
          <div class="overlay"><h3>Lappeenranta</h3></div>
        </a>
        <a href="/imatra" class="destination-card">
          <img src="/images/blog/imatrankoski.jpg" alt="Imatra">
          <div class="overlay"><h3>Imatra</h3></div>
        </a>
        <a href="/retkeily" class="destination-card">
          <img src="https://images.unsplash.com/photo-1544787219-7f47ccb76574?auto=format&fit=crop&q=80" alt="Retkeily">
          <div class="overlay"><h3>Retkeilyalueet</h3></div>
        </a>
      </div>
    </div>
  </section>

  <!-- Фотогалерея -->
  <section class="section gallery-section">
    <div class="container">
      <h2 class="section-title">Galleria – Etelä-Karjala kauneimmillaan</h2>
      <div class="gallery-grid">
        <img src="/images/hero/finland-hero.jpg" alt="Saimaa kesällä" loading="lazy">
        <img src="/images/blog/lappeenranta.jpg" alt="Lappeenrannan satama" loading="lazy">
        <img src="/images/blog/imatrankoski.jpg" alt="Imatrankoski" loading="lazy">
        <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&q=80" alt="Saimaan saaret" loading="lazy">
        <img src="https://images.unsplash.com/photo-1544787219-7f47ccb76574?auto=format&fit=crop&q=80" alt="Metsäpolku" loading="lazy">
        <img src="https://images.unsplash.com/photo-1564507592333-cdd0f3d6c4c6?auto=format&fit=crop&q=80" alt="Kylpylä" loading="lazy">
      </div>
    </div>
  </section>

  <!-- Видео -->
  <section class="section video-section">
    <div class="container">
      <h2 class="section-title">Video: Saimaa kutsuu</h2>
      <div class="video-wrapper">
        <iframe 
          src="https://www.youtube.com/embed/dQw4w9wgxcq" 
          title="Saimaa - Etelä-Karjala" 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen>
        </iframe>
      </div>
      <p class="video-caption">Koe Saimaan kauneus videolta (voit заменить ссылку на своё видео)</p>
    </div>
  </section>

</PageLayout>

<style>
  .hero {
    height: 100vh;
    min-height: 720px;
    background: url('/images/hero/finland-hero.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
    position: relative;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,80,90,0.35), rgba(0,45,70,0.78));
  }

  .hero-content h1 {
    font-size: clamp(3.8rem, 9vw, 7.5rem);
    font-weight: 800;
    line-height: 1.05;
    text-shadow: 0 4px 25px rgba(0,0,0,0.6);
  }

  .lead {
    font-size: clamp(1.45rem, 4vw, 2.2rem);
    margin-top: 1rem;
    opacity: 0.95;
  }

  .tp-widget-wrapper {
    max-width: 720px;
    margin: 2.5rem auto 0;
    background: rgba(255,255,255,0.96);
    border-radius: 20px;
    padding: 1.8rem;
    box-shadow: 0 15px 45px rgba(0,0,0,0.25);
  }

  .section {
    padding: 6rem 0;
  }

  .section-title {
    text-align: center;
    font-size: 2.8rem;
    margin-bottom: 3.5rem;
    color: #1a2a2a;
  }

  /* Галерея */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.2rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .gallery-grid img {
    width: 100%;
    height: 320px;
    object-fit: cover;
    border-radius: 18px;
    transition: all 0.4s ease;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
  }

  .gallery-grid img:hover {
    transform: scale(1.05);
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  /* Видео */
  .video-section {
    background: #f8f9f7;
  }

  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
    border-radius: 20px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.15);
    max-width: 1000px;
    margin: 0 auto;
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .video-caption {
    text-align: center;
    margin-top: 1.5rem;
    color: #555;
    font-style: italic;
  }

  /* Карточки направлений */
  .destinations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2rem;
    padding: 0 1.5rem;
  }

  .destination-card {
    position: relative;
    height: 380px;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 12px 35px rgba(0,0,0,0.12);
  }

  .destination-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .destination-card:hover img {
    transform: scale(1.1);
  }

  .overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85), transparent);
    color: white;
    padding: 2rem 1.8rem 1.8rem;
  }

  .overlay h3 {
    font-size: 1.8rem;
  }

  @media (max-width: 768px) {
    .gallery-grid img { height: 240px; }
  }
</style>
