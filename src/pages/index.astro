---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout 
  title="Matkatoimisto Saimaan Liikenne OY" 
  description="Unohtumattomat lomat Saimaalla – Imatra, Lappeenranta ja Etelä-Karjalan luontokohteet">
  
  <!-- Hero Section -->
  <div class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Tervetuloa<br>Saimaalle</h1>
      <p class="lead">Ainutlaatuisia elämyksiä, upeaa luontoa ja unohtumattomia lomia Etelä-Karjalassa</p>
      
  <!-- Destinations Section -->
  <section class="section destinations">
    <div class="container">
      <h2 class="section-title">Löydä unelmiesi kohde</h2>
      <div class="destinations-grid">

        <!-- Lappeenranta -->
        <a href="/lappeenranta" class="destination-card">
          <img src="/images/blog/lappeenranta.jpg" alt="Lappeenranta">
          <div class="card-overlay">
            <h3>Lappeenranta</h3>
            <p>Saimaan helmi, kaunis satama ja vilkas kaupunki</p>
          </div>
        </a>

        <!-- Imatra -->
        <a href="/imatra" class="destination-card">
          <img src="/images/blog/imatrankoski.jpg" alt="Imatra">
          <div class="card-overlay">
            <h3>Imatra</h3>
            <p>Voimakas Imatrankoski ja upea luonto</p>
          </div>
        </a>

        <!-- Retkeily -->
        <a href="/puistot" class="destination-card">
          <img src="/images/blog/ranta.jpg" alt="Retkeily">
          <div class="card-overlay">
            <h3>Kansallispuistot & Retkeily</h3>
            <p>Petkeljärvi, Ruunaa ja upeat luontoreitit</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Why Us Section -->
  <section class="section why-us">
    <div class="container">
      <h2 class="section-title">Miksi valita meidät?</h2>
      <div class="features">
        <div class="feature">
          <div class="feature-icon">🌲</div>
          <h3>Lähellä luontoa</h3>
          <p>Autamme sinua löytämään parhaat luontokohteet ja retkeilyreitit.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">🏨</div>
          <h3>Laadukkaat majoitukset</h3>
          <p>Hotellit, kylpylät ja mökit Saimaan rannalla.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">✈️</div>
          <h3>Helppo matkustaminen</h3>
          <p>Lentojen, junien ja majoituksen varaaminen samasta paikasta.</p>
        </div>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .hero {
    height: 100vh;
    min-height: 720px;
    background: url('/images/hero/finland-hero.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
    position: relative;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 80, 90, 0.35) 0%,
      rgba(0, 50, 70, 0.75) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    padding: 0 1.5rem;
  }

  .hero h1 {
    font-size: clamp(3.8rem, 9vw, 7.2rem);
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 1.2rem;
    text-shadow: 0 4px 25px rgba(0,0,0,0.6);
  }

  .lead {
    font-size: clamp(1.4rem, 4vw, 2.1rem);
    margin-bottom: 2.8rem;
    opacity: 0.95;
  }

  .tp-widget-wrapper {
    max-width: 720px;
    margin: 0 auto;
    background: rgba(255,255,255,0.96);
    border-radius: 20px;
    padding: 1.8rem;
    box-shadow: 0 15px 45px rgba(0,0,0,0.25);
  }

  /* Destinations */
  .destinations {
    padding: 6rem 0;
    background: #f8f9f7;
  }

  .section-title {
    text-align: center;
    font-size: 2.6rem;
    margin-bottom: 3.5rem;
    color: #1a2a2a;
  }

  .destinations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 2rem;
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .destination-card {
    position: relative;
    height: 420px;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 15px 35px rgba(0,0,0,0.12);
    transition: transform 0.4s ease;
    text-decoration: none;
    color: white;
  }

  .destination-card:hover {
    transform: translateY(-15px);
  }

  .destination-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .destination-card:hover img {
    transform: scale(1.08);
  }

  .card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.3));
    padding: 2.5rem 2rem 2rem;
  }

  .card-overlay h3 {
    font-size: 1.85rem;
    margin-bottom: 0.6rem;
  }

  /* Features */
  .why-us {
    padding: 6rem 0;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .feature {
    background: white;
    padding: 2.8rem 2rem;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
  }

  .feature-icon {
    font-size: 3.2rem;
    margin-bottom: 1.4rem;
  }

  .feature h3 {
    font-size: 1.55rem;
    margin-bottom: 1rem;
    color: #006666;
  }

  @media (max-width: 768px) {
    .hero { height: 85vh; }
    .destinations-grid {
      grid-template-columns: 1fr;
    }

  @media (max-width: 768px) {
    .hero {
      height: 85vh;
      min-height: 520px;
    }

    .section {
      padding: 4rem 0;
    }

    .section-title {
      font-size: 2.2rem;
      margin-bottom: 2.5rem;
    }

    .destinations-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .destination-card {
      height: 280px;
    }

    .gallery-grid {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.8rem;
    }

    .gallery-grid img {
      height: 220px;
    }

    .tp-widget-wrapper {
      margin: 1.5rem 1rem;
      padding: 1.2rem;
    }
  }

  @media (max-width: 480px) {
    .article-box, .tp-widget-wrapper {
      padding: 1.8rem 1.2rem;
    }

    .hero h1 {
      font-size: 2.8rem;
    }

    .lead {
      font-size: 1.25rem;
    }
  }
</style>
