---
// src/pages/index.astro
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Matkalla ilman rajoja | Unelmiesi loma">
  <div class="hero">
    <div class="hero-overlay"></div>
    
    <div class="hero-content">
      <h1>Avaa maailma<br> kanssamme</h1>
      <p class="lead">Matkoja, jotka jäävät mieleen ikuisesti</p>
      
      <div class="search-box">
        <input type="text" placeholder="Minne haluat matkustaa?" class="search-input" />
        <button class="search-btn">Etsi matka</button>
      </div>
      
      <div class="popular-destinations">
        <span>Suositut kohteet:</span>
        <div class="tags">
          <a href="#">Bali</a>
          <a href="#"> Islanti</a>
          <a href="#"> Georgia</a>
          <a href="#"> Japani</a>
          <a href="#"> Italia</a>
          <a href="#"> Turkki</a>
        </div>
      </div>
    </div>
  </div>

  <section class="section quick-info">
    <div class="container">
      <div class="cards">
        <div class="card">
          <div class="card-icon">✈️</div>
          <h3>Viime hetken matkat</h3>
          <p>Parhaat hinnat lähiajoille</p>
        </div>
        <div class="card">
          <div class="card-icon">🌴</div>
          <h3>Eksklusiiviset reitit</h3>
          <p>Paikat, joita ei löydy oppaista</p>
        </div>
        <div class="card">
          <div class="card-icon">💎</div>
          <h3>Paras hinta</h3>
          <p>Hinta-takuu</p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* sama tyyli kuin aiemmin – ei muutoksia */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 720px;
    background: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&q=80&w=2400') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 128, 128, 0.25) 0%,
      rgba(0, 128, 128, 0.55) 50%,
      rgba(0, 80, 100, 0.85) 100%
    );
    mix-blend-mode: multiply;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    padding: 0 20px;
  }

  h1 {
    font-size: clamp(3.2rem, 8vw, 6.5rem);
    font-weight: 800;
    line-height: 0.95;
    margin-bottom: 1.5rem;
    text-shadow: 0 4px 12px rgba(0,0,0,0.5);
  }

  .lead {
    font-size: clamp(1.4rem, 4vw, 2rem);
    margin-bottom: 2.5rem;
    opacity: 0.95;
  }

  .search-box {
    display: flex;
    max-width: 580px;
    margin: 0 auto 2.5rem;
    background: rgba(255,255,255,0.95);
    border-radius: 60px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.25);
  }

  .search-input {
    flex: 1;
    padding: 1.1rem 1.8rem;
    border: none;
    font-size: 1.15rem;
    background: transparent;
  }

  .search-btn {
    padding: 0 2.2rem;
    background: #00b7b7;
    color: white;
    border: none;
    font-weight: bold;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .search-btn:hover {
    background: #009999;
  }

  .popular-destinations {
    font-size: 1.1rem;
    opacity: 0.9;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    justify-content: center;
    margin-top: 1rem;
  }

  .tags a {
    background: rgba(255,255,255,0.25);
    backdrop-filter: blur(6px);
    padding: 0.5rem 1.3rem;
    border-radius: 30px;
    color: white;
    text-decoration: none;
    transition: all 0.25s;
  }

  .tags a:hover {
    background: rgba(255,255,255,0.45);
    transform: translateY(-2px);
  }

  .quick-info {
    padding: 5rem 0 7rem;
    background: linear-gradient(to bottom, #f8ffff, #e6f4f4);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .card {
    background: white;
    border-radius: 16px;
    padding: 2.2rem 1.8rem;
    text-align: center;
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.12);
  }

  .card-icon {
    font-size: 3.2rem;
    margin-bottom: 1rem;
  }

  .card h3 {
    color: #006666;
    margin-bottom: 0.8rem;
  }

  @media (max-width: 640px) {
    .search-box {
      flex-direction: column;
      border-radius: 20px;
    }
    
    .search-btn {
      padding: 1.2rem;
      border-radius: 0 0 20px 20px;
    }
  }
</style>
