---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Matkailu Suomessa – reitit, luonto ja rauha"
  description="Turistinen sivusto Suomesta: luontoreitit, kaupungit, blogi ja rauhallinen matkailu."
>

  <section class="hero">
  <div class="hero-overlay">
    <h1>Matkatoimisto Saimaan Liikenne OY</h1>
    <p>
      Löydä Suomen kauneimmat luontokohteet,
      reitit ja rauhallinen matkailu.
    </p>

    <a href="/routes" class="cta">Tutustu reitteihin</a>
  </div>
</section>


  <!-- SECTION 1 -->
  <section class="section fade-in">
    <div class="image">
      <img src="/images/routes/seasons.jpg" alt="Boat tours on Lake Saimaa" />
    </div>
    <div class="text">
      <h2>Exclusive Boat Tours</h2>
      <p>
        Discover the beauty of Lake Saimaa with our premium guided cruises.
        Enjoy peaceful waters, breathtaking landscapes and unforgettable moments.
      </p>
    </div>
  </section>

  <!-- SECTION 2 -->
  <section class="section reverse fade-in">
    <div class="image">
      <img src="/images/blog/winter-blog.jpg" alt="Finnish lake nature" />
    </div>
    <div class="text">
      <h2>Pure Nordic Nature</h2>
      <p>
        Experience clean air, crystal clear water and the silence of Finnish
        wilderness. Every cruise is designed for comfort and relaxation.
      </p>
    </div>
  </section>

  <!-- SECTION 3 -->
  <section class="section fade-in">
    <div class="image">
      <img src="/images/blog/forest-blog.jpg" alt="Sunset cruise" />
    </div>
    <div class="text">
      <h2>Sunset & Private Cruises</h2>
      <p>
        Celebrate special moments with our private sunset cruises.
        A luxurious atmosphere combined with breathtaking golden views.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <h2>Ready for an unforgettable journey?</h2>
    <a href="/contact" class="btn-primary">Contact Us</a>
  </section>

</PageLayout>

<style>
.hero {
  position: relative;
  min-height: 70vh;
  background-image: url("/images/hero/finland-hero.jpg");
  background-size: cover;
  background-position: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-overlay {
  background: rgba(0, 0, 0, 0.45);
  color: #ffffff;
  text-align: center;
  padding: 3rem 1.5rem;
  border-radius: 12px;
  max-width: 800px;
}

.hero h1 {
  font-size: 2.8rem;
  margin-bottom: 1rem;
}

.hero p {
  font-size: 1.2rem;
  margin-bottom: 2rem;
}

.cta {
  display: inline-block;
  background: #20c5c9;
  color: #ffffff;
  padding: 0.75rem 1.75rem;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 500;
}

.cta:hover {
  opacity: 0.9;
}
/* SECTIONS */
.section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  padding: 100px 10%;
}

.section.reverse {
  direction: rtl;
}

.section.reverse .text {
  direction: ltr;
}

.section img {
  width: 100%;
  height: 420px;
  object-fit: cover;
  border-radius: 20px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.15);
  transition: transform 0.4s ease;
}

.section img:hover {
  transform: scale(1.03);
}

.section h2 {
  font-size: 2rem;
  margin-bottom: 20px;
}

.section p {
  font-size: 1.1rem;
  line-height: 1.6;
}

/* ================= CTA ================= */

.cta {
  text-align: center;
  padding: 120px 20px;
  background: #0fa3b1;
  color: white;
}

.cta h2 {
  font-size: 2rem;
  margin-bottom: 30px;
}

/* ================= ANIMATION ================= */

.fade-in {
  opacity: 0;
  transform: translateY(50px);
  transition: all 0.8s ease;
}

.fade-in.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ================= RESPONSIVE ================= */

@media (max-width: 900px) {

  .hero {
    background-attachment: scroll;
  }

  .hero-content h1 {
    font-size: 2.2rem;
  }

  .section {
    grid-template-columns: 1fr;
    padding: 60px 20px;
  }

  .section.reverse {
    direction: ltr;
  }

  .section img {
    height: 300px;
  }
}

</style>

<script>
  const elements = document.querySelectorAll('.fade-in');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.2 });

  elements.forEach(el => observer.observe(el));
</script>
