---
import Layout from '../layouts/PageLayout.astro';
---

<Layout>

  <!-- ULTRA HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-glass">
      <span class="hero-label">Lake Saimaa • Finland</span>
      <h1>Saimaan Liikenne</h1>
      <p>Ultra-Premium Private Cruises & Nordic Experiences</p>
      <a href="/contact" class="btn-gold">Request a Private Cruise</a>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section class="lux-section fade">
    <div class="lux-image">
      <img src="/images/boats.jpg" alt="Luxury boat cruise Saimaa">
    </div>
    <div class="lux-text">
      <h2>Exceptional Experiences</h2>
      <p>
        Carefully curated private cruises designed for guests who value
        comfort, silence and exclusivity on Lake Saimaa.
      </p>
    </div>
  </section>

  <!-- NATURE -->
  <section class="lux-section reverse fade">
    <div class="lux-image">
      <img src="/images/nature.jpg" alt="Pure Finnish nature">
    </div>
    <div class="lux-text">
      <h2>Pure Nordic Nature</h2>
      <p>
        Crystal-clear waters, untouched landscapes and the rare luxury
        of absolute peace — nature as it was meant to be experienced.
      </p>
    </div>
  </section>

  <!-- SUNSET -->
  <section class="lux-section fade">
    <div class="lux-image">
      <img src="/images/sunset.jpg" alt="Sunset luxury cruise">
    </div>
    <div class="lux-text">
      <h2>Private Sunset Cruises</h2>
      <p>
        Golden reflections, champagne moments and unforgettable evenings
        designed exclusively for you and your guests.
      </p>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta">
    <h2>Your Private Journey Awaits</h2>
    <p>Limited availability • Tailored experiences only</p>
    <a href="/contact" class="btn-gold large">Begin Your Experience</a>
  </section>

</Layout>

<style>

/* ========== GLOBAL PREMIUM TONE ========== */

:root {
  --gold: #d4af37;
  --dark: #0b1f24;
}

body {
  background: #f8fbfc;
}

/* ========== HERO ========== */

.hero {
  position: relative;
  height: 100vh;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background-image: url('/images/hero/hero-premium.jpg');
  background-size: cover;
  background-position: center;
  transform: scale(1.1);
  will-change: transform;
}

.hero-glass {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  color: white;
  backdrop-filter: blur(6px);
  background: linear-gradient(
    rgba(0,0,0,0.45),
    rgba(0,0,0,0.65)
  );
  padding: 40px;
}

.hero-label {
  letter-spacing: 3px;
  text-transform: uppercase;
  font-size: 0.75rem;
  opacity: 0.8;
  margin-bottom: 20px;
}

.hero-glass h1 {
  font-size: 3.8rem;
  letter-spacing: 3px;
  margin-bottom: 20px;
}

.hero-glass p {
  font-size: 1.3rem;
  margin-bottom: 50px;
  opacity: 0.9;
}

/* ========== GOLD BUTTON ========== */

.btn-gold {
  padding: 14px 44px;
  border: 1px solid var(--gold);
  color: var(--gold);
  text-decoration: none;
  border-radius: 40px;
  letter-spacing: 1px;
  transition: all 0.4s ease;
}

.btn-gold:hover {
  background: var(--gold);
  color: black;
  transform: translateY(-3px);
}

.btn-gold.large {
  font-size: 1.1rem;
  padding: 18px 60px;
}

/* ========== LUX SECTIONS ========== */

.lux-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  padding: 140px 10%;
  align-items: center;
}

.lux-section.reverse {
  direction: rtl;
}

.lux-section.reverse .lux-text {
  direction: ltr;
}

.lux-image img {
  width: 100%;
  height: 480px;
  object-fit: cover;
  border-radius: 24px;
  box-shadow: 0 30px 60px rgba(0,0,0,0.2);
}

.lux-text h2 {
  font-size: 2.2rem;
  margin-bottom: 25px;
}

.lux-text p {
  font-size: 1.15rem;
  line-height: 1.7;
  color: #333;
}

/* ========== FINAL CTA ========== */

.final-cta {
  background: var(--dark);
  color: white;
  text-align: center;
  padding: 140px 20px;
}

.final-cta h2 {
  font-size: 2.4rem;
  margin-bottom: 20px;
}

.final-cta p {
  opacity: 0.8;
  margin-bottom: 40px;
}

/* ========== ANIMATION ========== */

.fade {
  opacity: 0;
  transform: translateY(60px);
  transition: all 1s ease;
}

.fade.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ========== MOBILE ========== */

@media (max-width: 900px) {

  .hero-glass h1 {
    font-size: 2.3rem;
  }

  .lux-section {
    grid-template-columns: 1fr;
    padding: 80px 20px;
  }

  .lux-image img {
    height: 320px;
  }
}

</style>

<script>
  /* Fade-in animation */
  const items = document.querySelectorAll('.fade');
  const observer = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.2 }
  );
  items.forEach(i => observer.observe(i));

  /* Subtle hero parallax */
  window.addEventListener('scroll', () => {
    const bg = document.querySelector('.hero-bg');
    bg.style.transform = `scale(1.1) translateY(${window.scrollY * 0.2}px)`;
  });
</script>
