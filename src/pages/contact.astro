---
import Layout from '../layouts/PageLayout.astro';
---

<Layout>

  <!-- HERO -->
  <section class="contact-hero">
    <div class="overlay"></div>
    <div class="hero-content">
      <h1>Contact Us</h1>
      <p>Design your private Lake Saimaa experience</p>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section class="contact-section">

    <div class="contact-card">
      <h2>Matkatoimisto Saimaan Liikenne OY</h2>

      <div class="contact-item">
        <span>📍 Address</span>
        <p>Kauppakatu 40 B 27<br />53100 Lappeenranta<br />Finland</p>
      </div>

      <div class="contact-item">
        <span>📞 Phone</span>
        <p><a href="tel:+358505568889">+358 50 556 8889</a></p>
      </div>

      <div class="contact-item">
        <span>✉ Email</span>
        <p><a href="mailto:info@saimaanliikenne.fi">info@saimaanliikenne.fi</a></p>
      </div>

      <div class="contact-item">
        <span>🕒 Availability</span>
        <p>Private bookings by reservation</p>
      </div>

    </div>

    <!-- MAP -->
    <div class="map-container">
      <iframe
        src="https://www.google.com/maps?q=Kauppakatu+40+Lappeenranta+Finland&output=embed"
        loading="lazy"
        allowfullscreen>
      </iframe>
    </div>

  </section>

</Layout>

<style>

/* ================= HERO ================= */

.contact-hero {
  position: relative;
  height: 55vh;
  background: url('/images/hero/hero-premium.jpg') center / cover fixed;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
}

.contact-hero .overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom,
    rgba(0,0,0,0.5),
    rgba(0,0,0,0.7));
}

.hero-content {
  position: relative;
  text-align: center;
  z-index: 2;
}

.hero-content h1 {
  font-size: 3rem;
  margin-bottom: 15px;
}

.hero-content p {
  font-size: 1.2rem;
  opacity: 0.9;
}

/* ================= CONTACT SECTION ================= */

.contact-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  padding: 100px 10%;
  background: #f8fafb;
}

.contact-card {
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(15px);
  border-radius: 24px;
  padding: 50px;
  box-shadow: 0 30px 70px rgba(0,0,0,0.15);
}

.contact-card h2 {
  margin-bottom: 40px;
  font-size: 2rem;
}

.contact-item {
  margin-bottom: 25px;
}

.contact-item span {
  display: block;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: #d4af37;
  margin-bottom: 5px;
}

.contact-item p {
  font-size: 1.1rem;
}

.contact-item a {
  text-decoration: none;
  color: #0fa3b1;
  font-weight: 500;
}

.contact-item a:hover {
  text-decoration: underline;
}

/* ================= MAP ================= */

.map-container {
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 30px 70px rgba(0,0,0,0.2);
}

.map-container iframe {
  width: 100%;
  height: 100%;
  min-height: 450px;
  border: 0;
}

/* ================= RESPONSIVE ================= */

@media (max-width: 900px) {

  .contact-hero {
    background-attachment: scroll;
  }

  .contact-section {
    grid-template-columns: 1fr;
    padding: 60px 20px;
  }

  .contact-card {
    padding: 35px;
  }

  .hero-content h1 {
    font-size: 2.2rem;
  }
}

</style>
