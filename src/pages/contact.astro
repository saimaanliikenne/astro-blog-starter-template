---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout 
  title="Yhteystiedot | Matkatoimisto Saimaan Liikenne OY" 
  description="Ota yhteyttä – Matkatoimisto Saimaan Liikenne OY">
  
  <!-- Hero -->
  <div class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Ota yhteyttä</h1>
      <p class="lead">Matkatoimisto Saimaan Liikenne OY</p>
    </div>
  </div>

  <section class="section contact-section">
    <div class="container">
      <div class="contact-box">
        
        <h2 class="contact-title">Yhteystiedot</h2>

        <div class="contact-grid">
          <div class="contact-item">
            <div class="icon">📍</div>
            <div>
              <h3>Osoite</h3>
              <p>Kauppakatu 40 B 27<br>
                 53100 Lappeenranta<br>
                 Finland</p>
            </div>
          </div>

          <div class="contact-item">
            <div class="icon">📞</div>
            <div>
              <h3>Puhelin</h3>
              <p><a href="tel:+358505568889">+358 50 556 8889</a></p>
            </div>
          </div>

          <div class="contact-item">
            <div class="icon">✉️</div>
            <div>
              <h3>Sähköposti</h3>
              <p><a href="mailto:info@saimaanliikenne.fi">info@saimaanliikenne.fi</a></p>
            </div>
          </div>

          <div class="contact-item">
            <div class="icon">🕒</div>
            <div>
              <h3>Aukioloajat</h3>
              <p>Ma–Pe: 10:00 – 18:00</p>
            </div>
          </div>
        </div>

        <!-- Интерактивная карта -->
        <div class="map-section">
          <h3 class="map-title">Löydä meidät kartalta</h3>
          <div class="map-container">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1981.057678678456!2d28.1885!3d61.0587!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4690e4f8f8f8f8f8%3A0xabcdef1234567890!2sKauppakatu%2040%2C%2053100%20Lappeenranta!5e0!3m2!1sfi!2sfi!4v1710000000000" 
              width="100%" 
              height="420" 
              style="border:0; border-radius: 20px;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>

        <!-- Форма обратной связи -->
        <div class="contact-form">
          <h3>Lähetä viesti</h3>
          <form action="#" method="POST">
            <input type="text" placeholder="Nimi" required>
            <input type="email" placeholder="Sähköposti" required>
            <input type="tel" placeholder="Puhelin">
            <textarea placeholder="Viesti" rows="6" required></textarea>
            <button type="submit" class="btn-primary">Lähetä viesti</button>
          </form>
        </div>

      </div>
    </div>
  </section>

</PageLayout>

<style>
  .hero {
    height: 75vh;
    min-height: 580px;
    background: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&q=80') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
    position: relative;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,80,90,0.4), rgba(0,50,70,0.75));
  }

  .contact-section {
    padding: 5rem 0 6rem;
    background: #f8f9f7;
  }

  .contact-box {
    max-width: 1000px;
    margin: 0 auto;
    background: white;
    padding: 4rem 3.5rem;
    border-radius: 24px;
    box-shadow: 0 15px 50px rgba(0,0,0,0.1);
  }

  .contact-title {
    text-align: center;
    font-size: 2.6rem;
    margin-bottom: 3rem;
    color: #1a2a2a;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2.5rem;
    margin-bottom: 4rem;
  }

  .contact-item {
    display: flex;
    gap: 1.2rem;
  }

  .icon {
    font-size: 2.3rem;
    flex-shrink: 0;
  }

  .contact-item h3 {
    color: #006666;
    margin-bottom: 0.6rem;
  }

  /* Карта */
  .map-section {
    margin: 3.5rem 0;
  }

  .map-title {
    text-align: center;
    margin-bottom: 1.5rem;
    color: #006666;
    font-size: 1.8rem;
  }

  .map-container {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 15px 40px rgba(0,0,0,0.12);
  }

  /* Форма */
  .contact-form {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid #eee;
  }

  .contact-form h3 {
    text-align: center;
    margin-bottom: 2rem;
    color: #006666;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  input, textarea {
    padding: 1rem 1.2rem;
    border: 1px solid #ddd;
    border-radius: 12px;
    font-size: 1.05rem;
  }

  .btn-primary {
    padding: 1.1rem;
    background: #30d5c8;
    color: white;
    border: none;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    margin-top: 1rem;
  }

  .btn-primary:hover {
    background: #00b7b7;
    transform: translateY(-3px);
  }

  /* Адаптивность */
  @media (max-width: 768px) {
    .contact-box {
      padding: 2.8rem 1.8rem;
      margin: 0 1rem;
    }
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .map-container iframe {
      height: 320px;
    }
  }
</style>
